# ── Google Sheets Configuration ───────────────────────────────
# Set SHEET_ID to enable Google Sheets mode (system_mode: "sheets")
# Leave blank to run in fallback mode (fully functional without Sheets)
SHEET_ID=your-google-sheet-id-here
WORKSHEET_NAME=VotePath_Data
ACCESS_MODE=auto
# ACCESS_MODE options: auto | public | service_account
CREDENTIALS_PATH=
# CREDENTIALS_PATH: path to service account JSON (only for service_account mode)

# ── Application Configuration ─────────────────────────────────
APP_NAME=VotePath AI Backend
APP_VERSION=1.0.0
PORT=8080
LOG_LEVEL=INFO

# ── CORS Configuration ────────────────────────────────────────
# Comma-separated allowed origins. Leave blank for safe local defaults.
# Example for Cloud Run: FRONTEND_ORIGINS=https://your-service.run.app
FRONTEND_ORIGINS=

# ── Performance Configuration ─────────────────────────────────
CACHE_ENABLED=true
RESPONSE_TIMEOUT_MS=500
